---
import type { CollectionEntry } from "astro:content";
import TeamMember from "./TeamMember.astro";

interface Props { authors: CollectionEntry<"authors">[] }
const { authors } = Astro.props;
---
<div class="carousel team" data-carousel>
  <div class="track" data-track>
    {authors.map((author) => (
      <div class="slide"><TeamMember author={author} /></div>
    ))}
  </div>
  <div class="dots" data-dots aria-label="Navigácia"></div>
</div>
<style>
  /* structure/dots come from global carousel.css; only per-view differs */
  .team { --per: 2; }
  @media (max-width: 991px) { .team { --per: 1; } }
</style>
<script>import "../scripts/carousel.js";</script>
