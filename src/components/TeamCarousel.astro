---
import type { CollectionEntry } from "astro:content";
import TeamMember from "./TeamMember.astro";

interface Props { authors: CollectionEntry<"authors">[] }
const { authors } = Astro.props;
---
<div class="carousel" data-team-carousel>
  <div class="track" data-track>
    {authors.map((author) => (
      <div class="slide"><TeamMember author={author} /></div>
    ))}
  </div>
  <div class="dots" data-dots aria-label="Navigácia"></div>
</div>
<style>
  .track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .track::-webkit-scrollbar { display: none; }
  .slide {
    flex: 0 0 50%;
    min-width: 0;
    scroll-snap-align: start;
    padding-inline: var(--space-2);
    box-sizing: border-box;
  }
  @media (max-width: 991px) {
    .slide { flex: 0 0 100%; }
  }
  .dots { display: flex; justify-content: center; gap: 0.6rem; margin-top: var(--space-4); }
  .dots button {
    width: 12px;
    height: 12px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid var(--color-primary);
    background: transparent;
    cursor: pointer;
  }
  .dots button[aria-current="true"] { background: var(--color-primary); }
</style>
<script>
  // Lightweight scroll-snap carousel (no autoplay). One scroll page per slide,
  // mirroring slick's slidesToScroll:1 / infinite:false (dots = slides - perView + 1).
  document.querySelectorAll("[data-team-carousel]").forEach((root) => {
    const track = root.querySelector("[data-track]");
    const dotsBox = root.querySelector("[data-dots]");
    if (!track || !dotsBox) return;
    const slides = Array.from(track.children);
    if (!slides.length) return;

    let pages = 0;
    const slideWidth = () => slides[0].getBoundingClientRect().width || 1;
    const perView = () => Math.max(1, Math.round(track.clientWidth / slideWidth()));

    const update = () => {
      const idx = Math.min(Math.round(track.scrollLeft / slideWidth()), pages - 1);
      Array.from(dotsBox.children).forEach((dot, i) =>
        dot.setAttribute("aria-current", i === idx ? "true" : "false")
      );
    };

    const build = () => {
      const next = Math.max(1, slides.length - perView() + 1);
      if (next !== pages) {
        pages = next;
        dotsBox.innerHTML = "";
        for (let i = 0; i < pages; i++) {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.setAttribute("aria-label", `Strana ${i + 1}`);
          dot.addEventListener("click", () =>
            track.scrollTo({ left: i * slideWidth(), behavior: "smooth" })
          );
          dotsBox.appendChild(dot);
        }
      }
      dotsBox.style.display = pages > 1 ? "flex" : "none";
      update();
    };

    let raf = 0;
    track.addEventListener("scroll", () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(update);
    }, { passive: true });
    window.addEventListener("resize", build);
    build();
  });
</script>
