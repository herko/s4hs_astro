---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { fullNameWithTitles } from "../lib/names";
import { plainText } from "../lib/excerpt";
import Icon from "./Icon.astro";
import noImage from "../assets/static/no-image.svg";
import noAvatar from "../assets/static/no-avatar.svg";

interface Props { post: CollectionEntry<"posts">; author: CollectionEntry<"authors"> }
const { post, author } = Astro.props;
const name = fullNameWithTitles(author.data);
const date = post.data.publishedAt.toLocaleDateString("sk-SK", { day: "numeric", month: "long", year: "numeric" });
const description = plainText(post.data.description);
---
<article class="post">
  <a href={`/clanky/${post.id}`} class="cover">
    <Image src={post.data.image ?? noImage} alt={post.data.title} width={760} height={500} />
  </a>
  <div class="body">
    <a class="byline" href={`/autori/${author.id}`}>
      <Image class="av" src={author.data.avatar ?? noAvatar} alt={name} width={40} height={40} />
      <span>{name}</span>
    </a>
    <small class="date">{date}</small>
    <h2><a href={`/clanky/${post.id}`}>{post.data.title}</a></h2>
    <p>{description}</p>
    <div class="more">
      <a class="btn" href={`/clanky/${post.id}`}>Celý článok <Icon name="arrow-right" size={16} /></a>
    </div>
  </div>
</article>
<style>
  .post { margin-bottom: var(--space-5); }
  .cover { display: block; }
  .cover :global(img) { width: 100%; height: auto; border-radius: var(--radius); box-shadow: var(--shadow-soft); }
  .body { padding-inline: var(--space-2); }
  .byline { display: inline-flex; align-items: center; gap: var(--space-1); color: var(--color-muted); padding-block: var(--space-2); }
  .byline .av { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; }
  .byline:hover { color: var(--color-primary); text-decoration: none; }
  .date { display: block; color: var(--color-muted); margin-bottom: 0.25rem; }
  .post h2 { font-size: var(--h4); margin: 0 0 var(--space-1); }
  .post h2 a { color: var(--color-text); }
  .post h2 a:hover { color: var(--color-primary); text-decoration: none; }
  .body p { margin: 0; color: var(--color-text); }
  .more { text-align: right; margin-top: var(--space-2); }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 0.4rem 1.1rem;
    border: 1px solid var(--color-primary); border-radius: 999px;
    color: var(--color-primary); font-size: 0.85rem;
  }
  .btn:hover { background: var(--color-primary); color: #fff; text-decoration: none; }
</style>
