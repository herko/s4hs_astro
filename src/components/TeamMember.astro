---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { fullNameWithTitles } from "../lib/names";
import { excerpt } from "../lib/excerpt";
import Icon from "./Icon.astro";
import noAvatar from "../assets/static/no-avatar.svg";

interface Props { author: CollectionEntry<"authors"> }
const { author } = Astro.props;
const name = fullNameWithTitles(author.data);
const bio = excerpt(author.body ?? "", 300);
---
<article class="member">
  <div class="text">
    <h3>{name}</h3>
    <p>{bio}</p>
    <a class="profile" href={`/autori/${author.id}`}>Profil autora <Icon name="arrow-right" size={16} /></a>
  </div>
  <div class="photo">
    <Image src={author.data.avatar ?? noAvatar} alt={name} width={333} height={500} />
  </div>
</article>
<style>
  .member {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    align-items: start;
  }
  .text { display: flex; flex-direction: column; }
  .text h3 { font-size: var(--h5); margin-bottom: var(--space-2); }
  .text p { color: var(--color-text); margin: 0 0 var(--space-3); }
  .profile {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-muted);
    border-radius: 999px;
    color: var(--color-text);
    font-size: 0.9rem;
  }
  .profile:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .photo :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }
  @media (max-width: 575px) {
    .member { grid-template-columns: 1fr; text-align: center; }
    .text { align-items: center; }
  }
</style>
