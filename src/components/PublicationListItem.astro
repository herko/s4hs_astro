---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { excerpt } from "../lib/excerpt";
import Icon from "./Icon.astro";
import noImage from "../assets/static/no-image.svg";

interface Props { publication: CollectionEntry<"publications"> }
const { publication } = Astro.props;
const description = excerpt(publication.data.shortDescription, 150);
---
<a class="pub" href={`/publikacie/${publication.id}`}>
  <Image class="cover" src={publication.data.image ?? noImage} alt={publication.data.title} width={240} height={336} />
  <div class="body">
    <h2>{publication.data.title}</h2>
    <p>{description}</p>
    <span class="more">Viac informácií <Icon name="arrow-right" size={14} /></span>
  </div>
</a>
<style>
  .pub {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: var(--space-3);
    align-items: start;
    padding: var(--space-3);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    height: 100%;
  }
  .pub:hover { box-shadow: var(--shadow-soft); text-decoration: none; }
  .cover {
    width: 110px;
    height: auto;
    max-height: 165px;
    object-fit: cover;
    border-radius: calc(var(--radius) / 1.5);
  }
  .body { min-width: 0; }
  .body h2 { font-size: 1.05rem; margin: 0 0 var(--space-1); }
  .pub:hover h2 { color: var(--color-primary); }
  .body p { margin: 0 0 var(--space-2); font-size: 0.9rem; color: var(--color-muted); }
  .more { display: inline-flex; align-items: center; gap: 4px; color: var(--color-primary); font-size: 0.85rem; }
</style>
