---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { excerpt } from "../lib/excerpt";
import Icon from "./Icon.astro";
import noImage from "../assets/static/no-image.svg";

interface Props { publication: CollectionEntry<"publications"> }
const { publication } = Astro.props;
const description = excerpt(publication.data.shortDescription, 200);
---
<article class="pub">
  <a href={`/publikacie/${publication.id}`} class="cover">
    <Image src={publication.data.image ?? noImage} alt={publication.data.title} width={500} height={700} />
  </a>
  <div class="body">
    <h2><a href={`/publikacie/${publication.id}`}>{publication.data.title}</a></h2>
    <p>{description}</p>
    <div class="more">
      <a class="btn" href={`/publikacie/${publication.id}`}>Viac informácií <Icon name="arrow-right" size={16} /></a>
    </div>
  </div>
</article>
<style>
  .pub { margin-bottom: var(--space-5); }
  .cover { display: block; }
  .cover :global(img) {
    display: block;
    margin-inline: auto;
    width: auto;
    max-width: 100%;
    max-height: 460px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }
  .body { padding-inline: var(--space-2); margin-top: var(--space-3); text-align: center; }
  .pub h2 { font-size: var(--h4); margin: 0 0 var(--space-1); }
  .pub h2 a { color: var(--color-text); }
  .pub h2 a:hover { color: var(--color-primary); text-decoration: none; }
  .body p { margin: 0 auto; max-width: 60ch; color: var(--color-text); }
  .more { margin-top: var(--space-2); }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 0.4rem 1.1rem;
    border: 1px solid var(--color-primary); border-radius: 999px;
    color: var(--color-primary); font-size: 0.85rem;
  }
  .btn:hover { background: var(--color-primary); color: #fff; text-decoration: none; }
</style>
