---
import { Image, getImage } from "astro:assets";
interface Props { images: import("astro").ImageMetadata[]; alt: string }
const { images, alt } = Astro.props;
// Pre-render a large version of each image for the lightbox.
const fulls = await Promise.all(images.map((img) => getImage({ src: img, width: 1600 })));
---
{images.length > 0 && (
  <div class="gallery">
    {images.map((img, i) => (
      <button type="button" class="thumb" data-full={fulls[i].src} data-full-alt={`${alt} — ${i + 1}`} aria-label={`Zväčšiť obrázok ${i + 1}`}>
        <Image src={img} alt={`${alt} — ${i + 1}`} width={400} height={300} />
      </button>
    ))}
  </div>
)}
<style>
  .gallery { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-2); margin-top: var(--space-3); }
  .thumb { padding: 0; border: 0; background: none; cursor: zoom-in; display: block; }
  .gallery :global(img) { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: var(--radius); display: block; }
</style>
<script>import "../scripts/lightbox.js";</script>
