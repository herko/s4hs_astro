---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/Icon.astro";
import { fullNameWithTitles } from "../../lib/names";
import noAvatar from "../../assets/static/no-avatar.svg";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({ params: { slug: author.id }, props: { author } }));
}
const { author } = Astro.props;
const { Content } = await render(author);
const name = fullNameWithTitles(author.data);
const { email, website, facebook, linkedin } = author.data;
---
<Layout title={`${name} — S4HS`}>
  <section class="hero">
    <div class="container"><h1>{name}</h1></div>
  </section>

  <section class="container profile">
    <a class="back-top" href="/autori"><Icon name="arrow-left" size={16} /> Späť na autorov</a>
    <Image class="photo" src={author.data.avatar ?? noAvatar} alt={name} width={400} height={600} />
    <div class="content">
      <div class="contacts">
        {email && <a class="seg email" href={`mailto:${email}`}><Icon name="mail" size={16} /> {email}</a>}
        {website && <a class="seg" href={website} aria-label="Web"><Icon name="globe" size={16} /></a>}
        {linkedin && <a class="seg" href={linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"><Icon name="linkedin" size={16} /></a>}
        {facebook && <a class="seg" href={facebook} target="_blank" rel="noopener" aria-label="Facebook"><Icon name="facebook" size={16} /></a>}
      </div>
      <hr />
      <div class="prose"><Content /></div>
    </div>
  </section>

  <section class="back-band">
    <a class="back" href="/autori"><Icon name="arrow-left" size={16} /> Späť na autorov</a>
  </section>
</Layout>
<style>
  .hero { background: var(--color-bg-light); padding-block: var(--space-5); text-align: center; }
  .hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: var(--weight-bold); }

  .profile {
    display: grid;
    grid-template-columns: minmax(240px, 1fr) 2fr;
    gap: var(--space-5);
    align-items: start;
    padding-block: var(--space-5);
    max-width: 980px;
  }
  .photo { width: 100%; height: auto; border-radius: var(--radius); box-shadow: var(--shadow-soft); }
  .back-top { grid-column: 1 / -1; display: inline-flex; align-items: center; gap: 6px; color: var(--color-muted); justify-self: start; }
  .back-top:hover { color: var(--color-primary); text-decoration: none; }

  .contacts { display: inline-flex; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; }
  .seg {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0.6rem 1rem;
    color: var(--color-muted);
    border-left: 1px solid var(--color-border);
  }
  .seg:first-child { border-left: 0; }
  .seg.email { color: var(--color-text); }
  .seg:hover { background: var(--color-bg-light); color: var(--color-primary); text-decoration: none; }
  .content hr { border: 0; border-top: 1px solid var(--color-border); margin-block: var(--space-3); }

  .back-band { background: var(--color-bg-light); text-align: center; padding-block: var(--space-4); }
  .back {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0.6rem 1.4rem;
    background: var(--color-primary); color: #fff;
    border-radius: 999px; font-size: 0.95rem;
  }
  .back:hover { background: var(--color-primary-dark); text-decoration: none; }

  @media (max-width: 767px) {
    .profile { grid-template-columns: 1fr; gap: var(--space-3); }
    .photo { max-width: 280px; margin-inline: auto; }
    .contacts { display: flex; flex-wrap: wrap; }
  }
</style>
